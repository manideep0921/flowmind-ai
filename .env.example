# ─────────────────────────────────────────────
# FlowMind AI — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Backend ──────────────────────────────────
BACKEND_PORT=4000
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://flowmind:flowmind_pass@localhost:5432/flowmind_db
POSTGRES_USER=flowmind
POSTGRES_PASSWORD=flowmind_pass
POSTGRES_DB=flowmind_db

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Service ───────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=internal-ai-service-secret

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Alerting (optional) ───────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=

# ── ChromaDB (vector store) ───────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
